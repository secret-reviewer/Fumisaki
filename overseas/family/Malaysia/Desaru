  <script>
    // Custom cursor
    (function () {
      var cursor = document.getElementById('cursor');
      var ring   = document.getElementById('cursor-ring');
      var mx = 0, my = 0, rx = 0, ry = 0;
      document.addEventListener('mousemove', function (e) {
        mx = e.clientX; my = e.clientY;
        cursor.style.left = mx + 'px';
        cursor.style.top  = my + 'px';
      });
      (function animRing() {
        rx += (mx - rx) * 0.12;
        ry += (my - ry) * 0.12;
        ring.style.left = rx + 'px';
        ring.style.top  = ry + 'px';
        requestAnimationFrame(animRing);
      })();
      document.querySelectorAll('a, button').forEach(function (el) {
        el.addEventListener('mouseenter', function () {
          ring.style.width = '56px'; ring.style.height = '56px';
          ring.style.borderColor = 'rgba(220,38,38,0.8)';
        });
        el.addEventListener('mouseleave', function () {
          ring.style.width = '36px'; ring.style.height = '36px';
          ring.style.borderColor = 'rgba(220,38,38,0.5)';
        });
      });
    })();

    // Progress bar
    window.addEventListener('scroll', function () {
      var scrollTop    = document.documentElement.scrollTop || document.body.scrollTop;
      var scrollHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      var pct = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
      document.getElementById('progress-bar').style.width = pct + '%';
    }, { passive: true });

    // Navbar scroll
    window.addEventListener('scroll', function () {
      var nav = document.getElementById('navbar');
      if (window.scrollY > 20) nav.classList.add('nav-scrolled');
      else nav.classList.remove('nav-scrolled');
    }, { passive: true });

    // Mobile menu
    document.getElementById('menu-toggle').addEventListener('click', function () {
      var menu      = document.getElementById('mobile-menu');
      var openIcon  = document.getElementById('menu-icon-open');
      var closeIcon = document.getElementById('menu-icon-close');
      var isOpen    = menu.style.maxHeight === '320px';
      menu.style.maxHeight    = isOpen ? '0' : '320px';
      menu.style.borderBottom = isOpen ? '' : '1px solid rgba(127,29,29,0.3)';
      openIcon.style.display  = isOpen ? '' : 'none';
      closeIcon.style.display = isOpen ? 'none' : '';
    });
    document.querySelectorAll('.mobile-link').forEach(function (link) {
      link.addEventListener('click', function () {
        document.getElementById('mobile-menu').style.maxHeight = '0';
        document.getElementById('menu-icon-open').style.display  = '';
        document.getElementById('menu-icon-close').style.display = 'none';
      });
    });

    // Scramble / decrypt effect
    var scrambleChars = 'ABCDEF0123456789/X$#@%';
    function decryptText(button, originalText, callback) {
      var iterations = 0;
      button.classList.add('decrypting');
      button.disabled = true;
      var interval = setInterval(function () {
        button.querySelector('span').innerText = originalText.split('').map(function (char, index) {
          if (index < iterations) return originalText[index];
          return char === ' ' ? ' ' : scrambleChars[Math.floor(Math.random() * scrambleChars.length)];
        }).join('');
        if (iterations >= originalText.length) {
          clearInterval(interval);
          button.classList.remove('decrypting');
          button.querySelector('span').innerText = originalText;
          button.disabled = false;
          callback();
        }
        iterations += 1 / 3;
      }, 30);
    }

    // Log navigation
    var logs        = document.querySelectorAll('.log-entry');
    var nextBtn     = document.getElementById('nextBtn');
    var prevBtn     = document.getElementById('prevBtn');
    var currentPage = document.getElementById('current-page');
    var totalPages  = document.getElementById('total-pages');
    var currentLogIndex = 0;

    totalPages.textContent = String(logs.length).padStart(2, '0');

    function updateButtons() {
      prevBtn.disabled = currentLogIndex === 0;
      nextBtn.disabled = currentLogIndex === logs.length - 1;
      currentPage.textContent = String(currentLogIndex + 1).padStart(2, '0');
    }

    function updateView(newIndex) {
      logs.forEach(function (log) { log.style.display = 'none'; });
      currentLogIndex = newIndex;
      logs[currentLogIndex].style.display = 'block';
      logs[currentLogIndex].style.animation = 'none';
      logs[currentLogIndex].offsetHeight;
      logs[currentLogIndex].style.animation = '';
      window.scrollTo({ top: 0, behavior: 'smooth' });
      updateButtons();
    }

    nextBtn.addEventListener('click', function () {
      if (currentLogIndex >= logs.length - 1) return;
      var nextIndex = currentLogIndex + 1;
      decryptText(nextBtn, 'Decrypt Next ►', function () { updateView(nextIndex); });
    });

    prevBtn.addEventListener('click', function () {
      if (currentLogIndex <= 0) return;
      var prevIndex = currentLogIndex - 1;
      decryptText(prevBtn, '◄ Previous File', function () { updateView(prevIndex); });
    });

    updateView(0);

    function toggleIntel(id, btn) {
      var report = document.getElementById(id);
      var isHidden = report.classList.contains('hidden');
      if (isHidden) {
        report.classList.remove('hidden');
        btn.innerText = 'CLOSE INTEL REPORT';
        report.querySelectorAll('p').forEach(function(p) {
          var html = p.innerHTML;
          html = html.replace(/(\d{4} HRS:)/g, '<br><span class="intel-timestamp">$1</span>');
          html = html.replace(/\n/g, '</p><p>');
          p.innerHTML = html;
        });
        report.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        report.classList.add('hidden');
        btn.innerText = 'ACCESS FULL INTEL REPORT';
      }
    }
  </script>

