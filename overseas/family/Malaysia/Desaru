    .glitch-wrap { position: relative; display: inline-block; }
    .glitch-wrap::before, .glitch-wrap::after {
      content: attr(data-text);
      position: absolute; top: 0; left: 0;
      width: 100%; height: 100%;
    }
    .glitch-wrap::before { color: #00ffff; animation: glitch-1 6s infinite step-start; opacity: 0.6; }
    .glitch-wrap::after  { color: var(--red); animation: glitch-2 6s infinite step-start; opacity: 0.6; }

    @keyframes glitch-1 {
      0%,100% { clip-path: inset(0 0 98% 0);  transform: translate(-2px,0); }
      20%     { clip-path: inset(20% 0 50% 0); transform: translate(2px,0); }
      40%     { clip-path: inset(60% 0 20% 0); transform: translate(-2px,0); }
      60%     { clip-path: inset(80% 0 5% 0);  transform: translate(2px,0); }
      80%     { clip-path: inset(40% 0 60% 0); transform: translate(-2px,0); }
    }
    @keyframes glitch-2 {
      0%,100% { clip-path: inset(50% 0 30% 0); transform: translate(2px,0);  color:#00ffff; }
